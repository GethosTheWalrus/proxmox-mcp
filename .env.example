# Proxmox connection
PROXMOX_HOST=192.168.1.100
PROXMOX_PORT=8006
PROXMOX_VERIFY_SSL=0

# Auth option 1: API token (recommended)
PROXMOX_USER=root@pam
PROXMOX_TOKEN_NAME=mcp
PROXMOX_TOKEN_VALUE=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Auth option 2: Password (uncomment and clear token vars above)
# PROXMOX_PASSWORD=your-password-here

# HuggingFace token (required for fine-tuning pipeline)
# Accept the Gemma license first: https://huggingface.co/google/functiongemma-270m-it
# HF_TOKEN=hf_your_token_here

# Fine-tuning compute platform: cpu, cu124 (NVIDIA CUDA 12.4), rocm6.2 (AMD)
# COMPUTE_PLATFORM=cpu

# AMD GPU architecture override (needed for newer GPUs not yet in PyTorch ROCm wheels)
# RDNA4 (RX 9000): 11.0.0 | RDNA3 (RX 7000): 11.0.0 | RDNA2 (RX 6000): 10.3.0
# HSA_OVERRIDE_GFX_VERSION=11.0.0
